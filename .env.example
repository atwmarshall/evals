# Ollama server URL — change if running Ollama on another machine or port
OLLAMA_HOST=http://localhost:11434

# Model used for eval runs (must be pulled in Ollama)
DEFAULT_MODEL=llama3.2:3b

# Model used by LLMJudge scorer (can be the same or a larger/smarter model)
JUDGE_MODEL=llama3.2:3b

# Model used by VariationGenerator to rewrite inputs (must differ from JUDGE_MODEL
# — using the same model to generate and score variations measures self-consistency,
# not scorer reliability, which is the wrong thing)
VARIATION_MODEL=mistral:7b

# Max tokens per completion
MAX_TOKENS=1024

# Where run results are saved
RESULTS_DIR=results/
